def create_video_from_frames(frames, output="mirage_promo.mp4", fps=24):
    clips = []
    for i, frame in enumerate(frames):
        frame_np = np.array(frame)
        clip = ImageClip(frame_np).set_duration(3)
        if i % 2 == 0:
            clip = clip.fx(vfx.fadein, 0.5).fx(vfx.fadeout, 0.5)
        clips.append(clip)
    final = concatenate_videoclips(clips)
    final.write_videofile(output, fps=fps, codec="libx264", audio_codec="aac")
    return output

