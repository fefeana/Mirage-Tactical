import subprocess
import sys
import importlib
import os

# ===================================================================
# 📦 1. دالة تثبيت المكتبات المفقودة وتحديثها تلقائياً
# ===================================================================

REQUIRED_PACKAGES = [
    "pillow",
    "moviepy",
    "numpy",
    "requests"
]

def install_and_update_packages(packages):
    """يتحقق من وجود المكتبات، ويُثبتها إذا لم تكن موجودة، ثم يُحدّثها"""
    for package in packages:
        try:
            importlib.import_module(package.replace("-", "_"))
            print(f"✅ {package} موجود بالفعل")
        except ImportError:
            print(f"📦 {package} غير موجود، جارٍ التثبيت...")
            subprocess.check_call([sys.executable, "-m", "pip", "install", package])
        
        # تحديث الحزمة إلى أحدث إصدار
        print(f"🔄 جارٍ تحديث {package}...")
        subprocess.check_call([sys.executable, "-m", "pip", "install", "--upgrade", package])

# تشغيل التثبيت والتحديث
install_and_update_packages(REQUIRED_PACKAGES)

