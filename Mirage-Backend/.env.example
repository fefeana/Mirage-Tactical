SECRET_KEY=MIRAGE_SUPER_SECRET_KEY_999_REPLACE_IN_PRODUCTION
# مفتاح فك التشفير (يتم إنتاجه مرة واحدة وحفظه في Google Secret Manager)
MIRAGE_ENCRYPTION_KEY=bV8yZ... (Base64 Key)
# مفتاح السنتينل المشفر (هذا ما تضعه أنت في Header اللوحة)
ENCRYPTED_SENTINEL_KEY=gAAAAABm... (Encrypted Payload)
DB_URL=postgresql://user:password@localhost/mirage_db
HETZNER_API_KEY=your_hetzner_api_key_here
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
